{
	"$schema": "https://gemini-cli.dev/schemas/settings.json",
	"model": {
		"default": "gemini-2.5-pro",
		"fast": "gemini-2.5-flash",
		"maxOutputTokens": 8192,
		"temperature": 0.2
	},
	"context": {
		"include": [
			"GEMINI.md",
			"src/content/**/*.mdx",
			"src/content/**/*.md",
			"src/content/config.ts",
			"src/components/**/*.astro",
			"src/layouts/**/*.astro",
			"astro.config.ts"
		],
		"exclude": [
			"dist/**",
			"node_modules/**",
			"**/*.generated.ts",
			".astro/**"
		],
		"maxFiles": 200,
		"maxTokens": 200000
	},
	"tools": {
		"shell": { "enabled": true, "policy": ".gemini/policies/shell.toml" },
		"read": { "enabled": true, "policy": ".gemini/policies/read.toml" },
		"write": { "enabled": true, "confirmBeforeWrite": true }
	},
	"defaults": {
		"showReasoning": false,
		"requireConfirmation": "on-destructive"
	},
	"telemetry": {
		"enabled": false
	}
}
