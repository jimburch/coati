# Files Gemini should not include in its context.

# Dependencies and build output
node_modules/
dist/
.astro/
.pagefind/
.cache/

# Image binaries — referenced via <Image>, not parsed as text
public/images/**/*.png
public/images/**/*.jpg
public/images/**/*.webp
public/images/**/*.avif
!public/images/**/README.md

# Font binaries
public/fonts/**

# Drafts (not yet ready for review)
src/content/drafts/

# Lockfile
pnpm-lock.yaml

# Secrets
.env
.env.*
!.env.example

# Build reports
.lighthouseci/
playwright-report/
