{
	"name": "claude-code-playground",
	"version": "1.0.0",
	"description": "local dev playground",
	"category": "web-dev",
	"agents": ["claude-code"],
	"placement": "global",
	"files": [
		{
			"path": ".claude/commands/review.md",
			"componentType": "command",
			"agent": "claude-code"
		},
		{
			"path": ".claude/commands/test-coverage.md",
			"componentType": "command",
			"agent": "claude-code"
		},
		{
			"path": ".claude/hooks/pre-commit.sh",
			"componentType": "hook",
			"agent": "claude-code"
		},
		{
			"path": ".claude/settings.json",
			"componentType": "instruction",
			"agent": "claude-code"
		},
		{
			"path": ".claude/skills/api-patterns/SKILL.md",
			"componentType": "skill",
			"agent": "claude-code"
		},
		{
			"path": ".mcp.json",
			"componentType": "mcp_server",
			"agent": "claude-code"
		},
		{
			"path": "CLAUDE.md",
			"componentType": "instruction",
			"agent": "claude-code"
		}
	]
}
