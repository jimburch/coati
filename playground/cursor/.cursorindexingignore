# Files Cursor should NOT include in its semantic index.
# Different from .cursorignore — these files can still be read when explicitly
# opened, but they won't appear in @-mentions or automatic retrieval.

# Source maps and type declaration bundles
**/*.d.ts
**/*.map

# Storybook build output
storybook-static/

# Chromatic baselines
.chromatic/

# Playwright snapshots (binary, noisy in context)
e2e/**/__screenshots__/

# Large generated icon sprite
src/icons/sprite.svg
