# Files Cursor should never read or include in prompts.
# These are separate from .gitignore — they exclude from AI context only.

# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
coverage/
storybook-static/
.turbo/
.vite/

# Generated files
src/**/*.generated.ts
src/**/*.generated.tsx

# Secrets
.env
.env.*
!.env.example
**/*.pem
**/*.key

# Large test fixtures and snapshots
**/__fixtures__/
**/__snapshots__/

# Package manager state
pnpm-lock.yaml
package-lock.json

# Logs and temp
*.log
.DS_Store
.idea/
.vscode/
