{
	"$schema": "https://gemini-cli.dev/schemas/settings.json",
	"model": {
		"default": "gemini-2.5-pro",
		"fast": "gemini-2.5-flash",
		"temperature": 0.2,
		"maxOutputTokens": 8192
	},
	"context": {
		"// include": "Project-level rules still apply — this is just the global layer",
		"include": [
			"~/.gemini/GEMINI.md"
		]
	},
	"defaults": {
		"style": "concise",
		"showReasoning": false,
		"requireConfirmation": "on-destructive"
	},
	"tools": {
		"shell": { "enabled": true, "confirmUnknownCommands": true },
		"read": { "enabled": true },
		"write": { "enabled": true, "confirmBeforeWrite": true }
	},
	"telemetry": {
		"enabled": false
	},
	"safety": {
		"denyReadGlobs": [
			".env",
			".env.*",
			"~/.ssh/**",
			"~/.aws/**",
			"~/.config/gh/**",
			"**/*.pem",
			"**/*.key"
		],
		"denyShellPatterns": [
			"rm -rf *",
			"git push --force*",
			"sudo *",
			"curl * | sh",
			"curl * | bash"
		]
	}
}
