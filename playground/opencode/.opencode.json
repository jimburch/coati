{
	"$schema": "https://opencode.ai/schemas/config.json",
	"provider": {
		"default": "anthropic",
		"fallback": ["openai", "google"],
		"anthropic": {
			"model": "claude-sonnet-4-5",
			"maxTokens": 8192
		},
		"openai": {
			"model": "gpt-5-codex"
		},
		"google": {
			"model": "gemini-2.5-pro"
		}
	},
	"mcpServers": {
		"filesystem": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-filesystem", "./app"]
		},
		"fetch": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-fetch"]
		},
		"playwright": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@playwright/mcp@latest"],
			"env": {
				"PLAYWRIGHT_HEADLESS": "true"
			}
		},
		"github": {
			"type": "stdio",
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-github"],
			"env": {
				"GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
			}
		}
	},
	"contextPaths": [
		"opencode.md",
		"app/composables/",
		"app/stores/",
		"nuxt.config.ts",
		".opencode/skills/"
	],
	"contextExclude": [
		"node_modules/**",
		".nuxt/**",
		"dist/**",
		".output/**",
		"**/*.generated.ts",
		".env*",
		"!.env.example"
	],
	"shell": {
		"allow": [
			"pnpm *",
			"npx vitest *",
			"npx eslint *",
			"npx nuxi *",
			"git status",
			"git diff*",
			"git log*"
		],
		"deny": [
			"rm -rf *",
			"git push --force*",
			"pnpm publish*",
			"curl * | sh",
			"curl * | bash"
		],
		"confirmOnMatch": true
	},
	"agents": {
		"directory": ".opencode/agents",
		"default": "general"
	},
	"output": {
		"style": "concise",
		"showReasoning": false,
		"showDiffs": true
	}
}
