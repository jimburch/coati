# Cursor should not read these files.
# Some of these are Claude's lane — keeping them out of context prevents
# Cursor from accidentally "helping" with backend code it shouldn't touch.

# Claude's lane (keep out of Cursor's context)
src/lib/server/
src/hooks.server.ts
**/+page.server.ts
**/+server.ts
src/routes/auth/
drizzle.config.ts

# Dependencies and build output
node_modules/
.svelte-kit/
build/
.turbo/

# Environment
.env
.env.*
!.env.example

# Lockfiles
pnpm-lock.yaml

# Test artifacts
playwright-report/
test-results/
coverage/

# Logs
*.log
.DS_Store
